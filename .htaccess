# Front-controller routing for the Research Repository app.
# Path-independent: works whether the project sits in /rvc.arch, /web, a domain
# root, or any other folder. No RewriteBase — the relative "index.php" target is
# resolved by Apache relative to THIS folder, so nothing is hardcoded.

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block direct web access to application internals (relative to this folder).
    RewriteRule ^(app|config|sql|views|storage)(/|$) - [F,L]

    # Serve real files and directories (assets, etc.) directly.
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Everything else goes through the front controller.
    RewriteRule ^ index.php [QSA,L]
</IfModule>

# Extra guard for sensitive file types (path-independent).
<FilesMatch "\.(sql|md)$">
    Require all denied
</FilesMatch>
